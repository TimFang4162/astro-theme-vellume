---
import type { CollectionEntry } from "astro:content";
import { getSeriesTitleMap } from "../../lib/blog";
import ViewCollection from "../ui/ViewCollection.astro";
import PostItem from "./PostItem.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
  defaultView?: "card" | "list";
  showViewToggle?: boolean;
  title?: string;
  description?: string;
}

const {
  posts,
  defaultView = "card",
  showViewToggle = false,
  title,
  description,
} = Astro.props;
const seriesTitleById = await getSeriesTitleMap();
---

<ViewCollection
  defaultView={defaultView}
  showViewToggle={showViewToggle}
  title={title}
  description={description}
>
  {posts.length === 0 && (
    <div class="surface-card p-6 text-sm leading-7 text-muted-foreground">
      暂无内容。添加文章后，这里会自动显示对应列表。
    </div>
  )}
  {posts.map((post) => (
    <PostItem
      post={post}
      view={defaultView}
      seriesTitle={post.data.series ? seriesTitleById.get(post.data.series.id) : undefined}
    />
  ))}
</ViewCollection>
