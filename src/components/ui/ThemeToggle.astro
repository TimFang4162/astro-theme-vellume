---
import { Icon } from "astro-icon/components";
import Button from "./Button.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<Button
  variant="ghost"
  shape="circle"
  size="md"
  class:list={["text-muted-foreground", className]}
  aria-label="切换主题"
  title="切换主题"
  data-theme-toggle
>
  <span class="block dark:hidden">
    <Icon name="material-symbols:sunny-outline-rounded" size={20} />
  </span>
  <span class="hidden dark:block">
    <Icon name="material-symbols:moon-stars-outline-rounded" size={20} />
  </span>
</Button>

<script>
import { handleToggleClick } from "astro-theme-toggle";
import { runOnPageLoad } from "../../scripts/ui/page-load";

let bound = false;

const getToggleOrigin = (toggle: HTMLElement, event: MouseEvent) => {
  if (event.clientX !== 0 || event.clientY !== 0) {
    return event;
  }

  const { left, top, width, height } = toggle.getBoundingClientRect();

  return {
    clientX: left + width / 2,
    clientY: top + height / 2,
  };
};

const initThemeToggle = () => {
  if (bound) {
    return;
  }

  bound = true;

  document.addEventListener("click", (event) => {
    if (!(event instanceof MouseEvent) || !(event.target instanceof Element)) {
      return;
    }

    const toggle = event.target.closest<HTMLElement>("[data-theme-toggle]");

    if (!toggle) {
      return;
    }

    handleToggleClick(getToggleOrigin(toggle, event));
  });
};

runOnPageLoad("ui:theme-toggle", initThemeToggle);
</script>
