---
import PostList from "../../components/blog/PostList.astro";
import SectionIntro from "../../components/ui/SectionIntro.astro";
import Layout from "../../layouts/BaseLayout.astro";
import { getPublicBlogPosts, getTagCounts } from "../../lib/blog";

export async function getStaticPaths() {
  const allPosts = await getPublicBlogPosts();
  const tags = getTagCounts(allPosts);

  return Array.from(tags.keys()).map((tag) => ({
    params: { tag },
    props: { tag, allPosts },
  }));
}

const { tag, allPosts } = Astro.props;
const filteredPosts = allPosts.filter((post) => post.data.tags.includes(tag));
---

<Layout title={`标签: ${tag}`}>
  <div class="page-stack">
    <SectionIntro
      title={`标签: ${tag}`}
      description="按标签归档的相关文章"
      fontStyle="reading"
      backHref="/tags"
      backLabel="返回标签页"
    />
    <PostList
      posts={filteredPosts}
      defaultView="card"
      description="这个标签下的全部文章"
      showViewToggle
    />
  </div>
</Layout>
