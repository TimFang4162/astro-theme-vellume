---
import { siteConfig } from "../config/site";
import { footerNavItems } from "../site/navigation";
import { withBasePath } from "../utils/paths";

const year = new Date().getFullYear();
const sitemapHref = withBasePath("/sitemap-index.xml");
---

<footer
  class="mt-16 border-t border-border bg-[color-mix(in_srgb,var(--muted)_50%,transparent)]"
>
  <div class="page-frame py-10 sm:py-12">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-[1.5fr_1fr_1fr]">
      <div class="flex h-full max-w-xs flex-col justify-between gap-4">
        <div>
          <span class="font-serif text-lg font-semibold text-strong">
            {siteConfig.site.title}
          </span>
          <p class="text-sm leading-relaxed text-muted-foreground">
            {siteConfig.author.tagline}
          </p>
        </div>
        <div class="text-sm leading-relaxed text-muted-foreground">
          <p>&copy; {year} {siteConfig.author.copyrightName}</p>
          <p set:html={siteConfig.site.attribution} />
        </div>
      </div>

      <nav aria-label="Footer navigation">
        <h3 class="mb-3 text-xs font-sans font-semibold text-strong">导航</h3>
        <ul class="m-0 flex list-none flex-col p-0">
          {footerNavItems.map((item) => (
            <li>
              <a
                href={withBasePath(item.href)}
                class="text-sm text-muted-foreground transition-colors hover:text-primary"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div>
        <h3 class="mb-3 text-xs font-sans font-semibold text-strong">链接</h3>
        <ul class="m-0 flex list-none flex-col p-0">
          <li>
            <a
              href={withBasePath(siteConfig.links.rss)}
              class="text-sm text-muted-foreground transition-colors hover:text-primary"
            >
              RSS
            </a>
          </li>
          <li>
            <a
              href={sitemapHref}
              class="text-sm text-muted-foreground transition-colors hover:text-primary"
            >
              Sitemap
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</footer>
