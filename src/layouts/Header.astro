---
import { Icon } from "astro-icon/components";
import NavLinks from "../components/navigation/NavLinks.astro";
import Button from "../components/ui/Button.astro";
import ThemeToggle from "../components/ui/ThemeToggle.astro";
import { siteConfig } from "../config/site";
import { withBasePath } from "../utils/paths";

interface Props {
  mobileDrawerEnabled?: boolean;
}

const { mobileDrawerEnabled = false } = Astro.props;
const currentPath = Astro.url.pathname;
const homeHref = withBasePath("/");
---

<header
  class="sticky top-0 z-50 border-b border-border/80 bg-background/96 backdrop-blur-xl"
>
  <div
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8"
  >
    <a href={homeHref}>
      <span class="font-serif text-xl font-semibold text-strong">
        {siteConfig.site.title}
      </span>
    </a>

    <div class="flex items-center gap-2">
      <NavLinks currentPath={currentPath} />
      <Button
        variant="ghost"
        shape="circle"
        size="md"
        aria-label="搜索"
        data-search-open
      >
        <Icon name="material-symbols:search-rounded" size={20} />
      </Button>
      <ThemeToggle
        class:list={[
          "shrink-0",
          mobileDrawerEnabled && "hidden md:inline-flex",
        ]}
      />
      {mobileDrawerEnabled && (
          <Button
            id="mobile-menu-button"
            variant="ghost"
            shape="circle"
            size="md"
            class="bg-background/90 shadow-sm md:hidden"
            aria-label="切换侧边栏"
            aria-controls="mobile-drawer"
            aria-expanded="false"
          >
            <Icon
              name="material-symbols:menu-rounded"
              size={24}
              class="menu-icon"
            />
            <Icon
              name="material-symbols:close-rounded"
              size={24}
              class="close-icon hidden"
            />
          </Button>
        )}
    </div>
  </div>
</header>

<script>
import { initMobileMenu } from "../scripts/ui/mobile-menu";
import { runOnPageLoad } from "../scripts/ui/page-load";

runOnPageLoad(initMobileMenu);
</script>
